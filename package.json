{
  "name": "front-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:profile": "tsc -b && vite build --mode production",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "e2e": "start-server-and-test \"npm run dev -- --host 0.0.0.0 --port 5173\" http://127.0.0.1:5173 \"cypress run\"",
    "preview": "vite preview",
    "prepare": "husky",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/pro-components": "^2.8.10",
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "antd": "^5.29.3",
    "axios": "^1.13.6",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "i18next": "^25.10.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "qs": "^6.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^16.6.2",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.2",
    "vite-plugin-html": "^3.2.2",
    "yup": "^1.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-legacy": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "cypress": "^15.12.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "less": "^4.6.4",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.1.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-mock": "^3.0.2",
    "vite-plugin-theme": "^0.8.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,css,less}": [
      "prettier --write"
    ]
  }
}
